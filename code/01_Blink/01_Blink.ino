/*
 * STEM Engineering Workshop: From Embedded Systems to IoT and AI
 * กิจกรรมที่ 1.1: Blink LED - โปรแกรมแรกในชีวิต!
 * 
 * สิ่งที่เรียนรู้:
 * - โครงสร้างโปรแกรม Arduino (setup/loop)
 * - digitalWrite สั่ง LED ติด/ดับ
 * - delay หน่วงเวลา
 * 
 * การต่อวงจร:
 * ESP32 GPIO 2 → ตัวต้านทาน 220Ω → LED แดง (+) → GND (-)
 */

#define LED_RED 2   // LED แดง ต่อที่ขา GPIO 2

void setup() {
  pinMode(LED_RED, OUTPUT);   // ตั้งค่าขา LED เป็น OUTPUT (ส่งสัญญาณออก)
}

void loop() {
  digitalWrite(LED_RED, HIGH);  // สั่งให้ LED ติด
  delay(1000);                  // รอ 1000 มิลลิวินาที (1 วินาที)
  
  digitalWrite(LED_RED, LOW);   // สั่งให้ LED ดับ
  delay(1000);                  // รอ 1 วินาที
  
  // แล้ว loop จะวนกลับมาทำใหม่ → LED กระพริบไปเรื่อยๆ
}

